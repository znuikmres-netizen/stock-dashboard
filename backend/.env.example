# 本機開發用 sqlite 就好。
# 雲端 Railway 不會自動注入 DATABASE_URL：要在後端服務手動設參考變數
# DATABASE_URL=${{Postgres.DATABASE_URL}} 連到專案裡的 Postgres，
# 否則會退回下面的 sqlite，寫在容器暫存碟、每次 redeploy 就清空。
DATABASE_URL=sqlite:///./dev.db

# pipeline 推資料進 /api/ingest 時要帶這個 key
INGEST_API_KEY=change-me-to-a-long-random-string

# FinMind token（去 https://finmindtrade.com 申請，免費版即可）
FINMIND_TOKEN=

# 允許前端跨來源的網域，逗號分隔；本機開發用 *
CORS_ORIGINS=*
